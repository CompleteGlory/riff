default_platform(:android)

platform :android do
  desc "Android Firebase App Distribution"
  lane :firebase_distribution do
    # Run Flutter commands from project root
    Dir.chdir("..") do
      sh "flutter clean"
      sh "flutter build apk --release --flavor production --target lib/main_production.dart --no-tree-shake-icons"
    end

    firebase_app_distribution(
      app: "1:369305642937:android:5cc3706f66335b573d7868",
      firebase_cli_token: ENV["FIREBASE_CLI_TOKEN"],
      android_artifact_type: "APK",
      android_artifact_path: "../build/app/outputs/flutter-apk/app-production-release.apk",
      testers: "fadyalaa441@gmail.com, fadyalaa2112@gmail.com, zakymagd@gmail.com, magddevf@gmail.com" ,
      upload_timeout: 600,
      release_notes: <<~RELEASE_NOTES
        Version 1.0.7 — Huge update 

        Date: 2026-06-16

      RELEASE_NOTES
    )
  end
end
