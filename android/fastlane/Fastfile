default_platform(:android)

platform :android do
  desc "Android Firebase App Distribution"
  lane :firebase_distribution do
    # Run Flutter commands from project root
    Dir.chdir("..") do
      sh "flutter clean"
      sh "flutter build apk --release --flavor production --target lib/main_production.dart --no-tree-shake-icons"
    end

    firebase_app_distribution(
      app: "1:369305642937:android:5cc3706f66335b573d7868",
      firebase_cli_token: ENV["FIREBASE_CLI_TOKEN"],
      android_artifact_type: "APK",
      android_artifact_path: "../build/app/outputs/flutter-apk/app-production-release.apk",
      testers: "fadyalaa441@gmail.com, fadyalaa2112@gmail.com, zakymagd@gmail.com, magddevf@gmail.com" ,
      upload_timeout: 600,
      release_notes: <<~RELEASE_NOTES
        Version 1.0.3 — Release Notes
        Date: 2026-06-11

        ──────────────────────────────
        What's New
        ──────────────────────────────

        Multi-Image Posts
        - Create posts with up to 10 photos (gallery multi-select or camera).
        - Images shown inline in the feed: single full-width, 2-up side-by-side,
          3-up (tall left + 2 stacked right), 4+ as a 2×2 grid with a "+N" overlay.
        - Tap any image to open a full-screen swipeable gallery with page indicator.

        Profile Image Fullscreen
        - Tap your avatar on the profile screen to view it full-screen.
        - The camera edit badge still handles photo upload independently.

        Redesigned Feed UI
        - Cleaner post cards: lighter shadow, modern rounded corners.
        - Actions bar is now a compact inline row (♥ count · 💬 count · share).
        - Post header shows a proper avatar with initials fallback.

        Live Comment Avatars
        - Comment sheet now shows each commenter's real profile photo.
        - Your own avatar (including optimistic new comments) uses your cached
          profile image instead of a generic icon.

        ──────────────────────────────
        Bug Fixes & Improvements
        ──────────────────────────────
        - Fixed post images showing broken placeholders (Image.network routing).
        - Fixed profile image not displaying when URL is relative.
        - Updated firebase_app_distribution plugin to 1.0.x.

        ──────────────────────────────
        QA Checklist
        ──────────────────────────────
        1. Create Post — pick 1, 2, 3, 4, and 5+ images; verify grid layouts.
        2. Feed — tap image opens swipeable fullscreen viewer.
        3. Profile — tap avatar opens fullscreen; camera badge opens upload sheet.
        4. Comments — commenter avatars load; your avatar appears on new comment.
        5. Regression — like, comment, share, login/signup all unaffected.
      RELEASE_NOTES
    )
  end
end
